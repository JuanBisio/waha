    {
      "parameters": {
        "jsCode": "const body = $json.body || $json;\n\nlet sender = body?.whatsappInboundMessage?.from || body?.from || '';\nlet message = body?.whatsappInboundMessage?.text?.body || body?.text?.body || 'Hola';\nlet name = body?.whatsappInboundMessage?.customerProfile?.name || 'Cliente';\n\nreturn {\n  sender: String(sender).trim(),\n  message: String(message).trim(),\n  name: String(name).trim(),\n  shop_slug: 'demo'\n};"
      },
      "name": "Extract Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1456,
        1040
      ],
      "id": "6c82059b-cb43-4993-99ba-561dfca8c672"
    },
    {
      "parameters": {
        "jsCode": "const msg = $json.message.toLowerCase();\nconst now = new Date();\nconst pad = n => String(n).padStart(2,'0');\nconst iso = d => `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`;\n\nlet parsed_date = null;\n\nif (msg.includes('mañana')) parsed_date = iso(new Date(now.setDate(now.getDate()+1)));\n\nconst m1 = msg.match(/\\b(el|para)\\s+(\\d{1,2})\\b/);\nif (!parsed_date && m1) {\n  const d = new Date();\n  d.setDate(Number(m1[2]));\n  if (d < new Date()) d.setMonth(d.getMonth()+1);\n  parsed_date = iso(d);\n}\n\nreturn { ...$json, parsed_date };"
      },
      "name": "Parse Date",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1648,
        1040
      ],
      "id": "c375fed0-d9c3-4cf4-98c5-15890dea50bf"
    },
