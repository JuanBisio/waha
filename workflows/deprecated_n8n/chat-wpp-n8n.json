    {
      "parameters": {
        "jsCode": "const s = Array.isArray($json) ? $json[0] : $json;\nreturn {\n  phone: s.phone,\n  service: s.service,\n  professional: s.professional,\n  preferred_date: s.preferred_date,\n  preferred_time: s.preferred_time\n};"
      },
      "name": "Normalize Session",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2448,
        1040
      ],
      "id": "f74e6df8-75af-4a7e-a712-a5996d976dc7"
    },
    {
      "parameters": {
        "jsCode": "// Lee datos de otros nodos de forma segura (esto sí funciona en Code node)\nconst msg = String($items(\"Extract Message\")[0]?.json?.message ?? \"\").toLowerCase();\nconst sender = String($items(\"Extract Message\")[0]?.json?.sender ?? \"\").trim();\n\nconst ctx = $items(\"Normalize Context\")[0]?.json ?? {};\nconst session = $items(\"Normalize Session\")[0]?.json ?? {};\n\n// servicios/profesionales pueden venir como array o string\nconst services = Array.isArray(ctx.services)\n  ? ctx.services\n  : String(ctx.services ?? \"\").split(\",\").map(s => s.trim()).filter(Boolean);\n\nconst professionals = Array.isArray(ctx.professionals)\n  ? ctx.professionals\n  : String(ctx.professionals ?? \"\").split(\",\").map(s => s.trim()).filter(Boolean);\n\n// Detectar servicio por \"contiene\"\nlet service = null;\nfor (const s of services) {\n  const sKey = s.toLowerCase().split(\"(\")[0].trim(); // \"Barba y Perfilado\"\n  if (sKey && msg.includes(sKey)) {\n    service = sKey; \n    break;\n  }\n}\n\n// Detectar profesional por nombre completo o primer nombre\nlet professional = null;\nfor (const p of professionals) {\n  const pLower = p.toLowerCase();\n  const first = pLower.split(\" \")[0]; // joaquin, maria\n  if ((pLower && msg.includes(pLower)) || (first && msg.includes(first))) {\n    professional = p;\n    break;\n  }\n}\n\n// Fecha parseada desde tu nodo Parse Date (si existe)\nconst parsedDate = $items(\"Parse Date\")[0]?.json?.parsed_date ?? null;\n\n// Detectar Hora (Nuevo)\nlet extractedTime = null;\n// Matches: \"10:30\", \"10:00\", \"9:00\", \"09:00\"\nconst timeMatch1 = msg.match(/\\b(\\d{1,2}):(\\d{2})\\b/);\nif (timeMatch1) {\n  extractedTime = `${timeMatch1[1].padStart(2, '0')}:${timeMatch1[2]}:00`;\n} else {\n  // Matches: \"a las 9\", \"a las 10\"\n  const timeMatch2 = msg.match(/\\ba\\s+las?\\s+(\\d{1,2})\\b/);\n  if (timeMatch2) {\n    extractedTime = `${timeMatch2[1].padStart(2, '0')}:00:00`;\n  }\n}\n\n// Merge: NO pises con null lo que ya tenías en sesión\nreturn {\n  phone: sender || session.phone || null,\n  service: service || session.service || null,\n  professional: professional || session.professional || null,\n  preferred_date: parsedDate || session.preferred_date || null,\n  preferred_time: extractedTime || session.preferred_time || null,\n};\n"
      },
